---
import { config } from "@parseConfig"

const year = new Date().getFullYear()
const socialLinks = config.socialLinks
---

<footer
  class="mt-16 flex flex-col gap-y-3 pt-8 text-xs text-muted-foreground sm:text-sm"
>
  {
    socialLinks.length > 0 && (
      <nav class="flex flex-wrap gap-x-4 gap-y-1">
        {socialLinks.map((link) => (
          <a
            href={link.href}
            target={link.href.startsWith("mailto:") ? undefined : "_blank"}
            rel="me noopener noreferrer"
            class="underline decoration-muted-foreground/50 underline-offset-2 transition-colors duration-200 ease-out hover:text-foreground"
          >
            {link.label}
          </a>
        ))}
      </nav>
    )
  }

  <div class="flex items-baseline justify-between gap-x-4">
    <p>
      &copy; {year}
      <span class="font-medium text-foreground/80">{config.site.author}</span>
    </p>

    <p>
      Hecho con <a
        href="https://github.com/odhyp/astro-sidey"
        target="_blank"
        rel="noopener noreferrer"
        class="font-medium text-foreground/80 underline underline-offset-2 transition-colors duration-200 ease-out hover:text-foreground"
        >Astro Sidey</a
      >
    </p>
  </div>
</footer>
