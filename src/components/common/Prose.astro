---
interface Props {
  class?: string
}

const { class: className } = Astro.props
---

<div
  class:list={[
    // Base
    "prose max-w-none",

    // Body — medida cómoda y ritmo vertical amplio para lectura larga
    "prose-p:leading-[1.75] prose-p:text-foreground",

    // Heading — Fraunces (los ejes se fijan en global.css), sin negritas
    "prose-headings:font-display prose-headings:font-normal prose-headings:tracking-tight prose-headings:text-balance prose-headings:text-foreground",
    "prose-h1:text-[2rem] prose-h1:leading-[1.15] sm:prose-h1:text-[2.75rem]",
    "prose-h2:mt-12 prose-h2:text-2xl prose-h3:text-xl",
    "prose-h4:text-destructive prose-h5:text-destructive prose-h6:text-destructive", // We only use h1 to h3

    // Anchor — el subrayado es el enlace; el rojo marca el que estás señalando
    "prose-a:font-normal prose-a:text-foreground prose-a:no-underline",
    "prose-a:[background-image:linear-gradient(var(--color-border),var(--color-border))] prose-a:[background-size:100%_1px] prose-a:[background-position:0_100%] prose-a:[background-repeat:no-repeat]",
    "prose-a:transition-colors prose-a:duration-200 prose-a:ease-out prose-a:hover:text-primary",

    // Image
    "prose-img:cursor-zoom-in prose-img:rounded-none prose-img:shadow-none prose-img:transition-opacity prose-img:duration-200 prose-img:ease-out prose-img:hover:opacity-90",

    // List, markers, blockquote, strong, horizontal line
    "prose-ol:text-foreground prose-ul:text-foreground",
    "prose-li:marker:text-muted-foreground",
    // La cita se sangra con un filete fino y va en la serif del display
    "prose-blockquote:border-l prose-blockquote:border-l-primary/40 prose-blockquote:pl-5 prose-blockquote:font-display prose-blockquote:text-lg prose-blockquote:font-normal prose-blockquote:text-muted-foreground prose-blockquote:not-italic",
    "prose-strong:font-medium prose-strong:text-foreground",
    "prose-hr:my-12 prose-hr:border-0 prose-hr:border-t prose-hr:border-t-border/70",

    // Table
    "prose-thead:border-b prose-thead:border-foreground/25 prose-th:font-mono prose-th:text-xs prose-th:font-normal prose-th:tracking-[0.14em] prose-th:text-muted-foreground prose-th:uppercase",
    "prose-tr:border-b prose-tr:border-border/70",
    "prose-td:text-foreground",

    // Inline code
    "prose-code:rounded-none prose-code:bg-secondary prose-code:px-1.5 prose-code:py-0.5 prose-code:font-mono prose-code:text-[0.85em] prose-code:font-normal prose-code:text-foreground prose-code:before:content-none prose-code:after:content-none",
    className,
  ]}
>
  <slot />
</div>
