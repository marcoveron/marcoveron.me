---
interface Props {
  tags: string[]
}
const { tags } = Astro.props
---

{
  tags.length > 0 && (
    <div class="mt-12 border-t border-border/70 pt-4">
      <ul class="flex flex-wrap gap-x-4 gap-y-1">
        {tags.map((tag) => (
          <li class="eyebrow whitespace-nowrap">{tag}</li>
        ))}
      </ul>
    </div>
  )
}
