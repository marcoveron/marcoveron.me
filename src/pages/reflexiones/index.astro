---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getSortedPosts } from '../../utils';

const posts = await getSortedPosts('reflexiones');
---

<BaseLayout
  title="Reflexiones"
  description="Reflexiones breves, tipo diario, de Marco Verón."
>
  <h1>Reflexiones</h1>
  <p class="lead">Anotaciones breves, tipo diario. Ideas en voz alta.</p>

  {
    posts.length > 0 ? (
      <ul class="post-list">
        {posts.map((post) => (
          <PostCard
            href={`/reflexiones/${post.id}`}
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
          />
        ))}
      </ul>
    ) : (
      <p class="muted">Aún no hay reflexiones publicadas.</p>
    )
  }
</BaseLayout>
