---
import BaseLayout from '../layouts/BaseLayout.astro';
import { projects } from '../projects';
---

<BaseLayout
  title="Proyectos"
  description="Proyectos y trabajos de Marco Verón."
>
  <h1>Proyectos</h1>
  <p class="lead">Algunas cosas que he construido.</p>

  {
    projects.map((project) => (
      <div class="project">
        <h3>{project.name}</h3>
        {project.period && <p class="post-item-meta">{project.period}</p>}
        <p>{project.description}</p>
        {project.links && project.links.length > 0 && (
          <div class="project-links">
            {project.links.map((link) => (
              <a href={link.href} target="_blank" rel="noopener">
                {link.label} →
              </a>
            ))}
          </div>
        )}
      </div>
    ))
  }
</BaseLayout>
