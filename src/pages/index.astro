---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { site } from '../site.config';
import { getSortedPosts } from '../utils';

// Muestra las últimas entradas de cada colección en la portada.
const blog = (await getSortedPosts('blog')).slice(0, 4);
const reflexiones = (await getSortedPosts('reflexiones')).slice(0, 3);
---

<BaseLayout>
  <section>
    <h1>Hola, soy {site.title}.</h1>
    <p class="lead">{site.tagline}</p>
    <p>
      Este es mi espacio personal. Aquí escribo <a href="/blog">publicaciones</a>
      más elaboradas y guardo <a href="/reflexiones">reflexiones</a> breves, tipo
      diario. También puedes ver mis <a href="/proyectos">proyectos</a> o saber
      un poco <a href="/sobre-mi">sobre mí</a>.
    </p>
  </section>

  {
    blog.length > 0 && (
      <section>
        <div class="section-title">
          <h2>Últimas publicaciones</h2>
          <a href="/blog">Ver todas →</a>
        </div>
        <ul class="post-list">
          {blog.map((post) => (
            <PostCard
              href={`/blog/${post.id}`}
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
            />
          ))}
        </ul>
      </section>
    )
  }

  {
    reflexiones.length > 0 && (
      <section>
        <div class="section-title">
          <h2>Reflexiones recientes</h2>
          <a href="/reflexiones">Ver todas →</a>
        </div>
        <ul class="post-list">
          {reflexiones.map((post) => (
            <PostCard
              href={`/reflexiones/${post.id}`}
              title={post.data.title}
              date={post.data.date}
              description={post.data.description}
            />
          ))}
        </ul>
      </section>
    )
  }
</BaseLayout>
