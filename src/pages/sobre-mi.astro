---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site, socialLinks } from '../site.config';
---

<BaseLayout
  title="Sobre mí"
  description={`Sobre ${site.title}.`}
>
  <h1>Sobre mí</h1>

  <p class="lead">
    Reemplaza este texto por una breve presentación tuya.
  </p>

  <p>
    Aquí puedes contar quién eres, a qué te dedicas y qué temas te interesan.
    Un par de párrafos bastan. Este contenido está en
    <code>src/pages/sobre-mi.astro</code>, edítalo cuando quieras.
  </p>

  <p>
    Si quieres añadir una foto, coloca la imagen en la carpeta
    <code>public/</code> (por ejemplo <code>public/foto.jpg</code>) y añádela así:
    <code>&lt;img src="/foto.jpg" alt="Marco Verón" /&gt;</code>.
  </p>

  <h2>Dónde encontrarme</h2>
  <ul>
    {
      socialLinks.map((link) => (
        <li>
          <a href={link.href} target="_blank" rel="me noopener">
            {link.label}
          </a>
        </li>
      ))
    }
  </ul>
</BaseLayout>
