---
import BaseLayout from './BaseLayout.astro';
import { formatDate, isoDate } from '../utils';

interface Props {
  title: string;
  date: Date;
  description?: string;
  tags?: string[];
  /** Texto y enlace de "volver" (p. ej. al listado de la colección). */
  backHref: string;
  backLabel: string;
}

const { title, date, description, tags = [], backHref, backLabel } =
  Astro.props;
---

<BaseLayout title={title} description={description}>
  <article>
    <a class="back-link" href={backHref}>← {backLabel}</a>
    <header class="post-header">
      <h1>{title}</h1>
      <time class="post-item-meta" datetime={isoDate(date)}>
        {formatDate(date)}
      </time>
    </header>

    <div class="post-content">
      <slot />
    </div>

    {
      tags.length > 0 && (
        <ul class="tag-list">
          {tags.map((tag) => (
            <li>#{tag}</li>
          ))}
        </ul>
      )
    }
  </article>
</BaseLayout>
