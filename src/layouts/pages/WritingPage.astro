---
import BaseLayout from "@layouts/BaseLayout.astro"
import Prose from "@components/common/Prose.astro"
import PostTags from "@components/common/PostTags.astro"
import Back from "@components/common/Back.astro"
import { formatDate } from "@utils/formatDate"

const { frontmatter, readingTime } = Astro.props
const { title, description, date, tags } = frontmatter.data

const formattedDate = formatDate(date, "long")
const isoDate = date.toISOString().split("T")[0]
---

<BaseLayout title={title} description={description}>
  <article>
    <header class="mb-10">
      <p class="eyebrow">
        <time datetime={isoDate}>{formattedDate}</time>
        <span aria-hidden="true"> · </span>
        <span>{readingTime}</span>
      </p>

      <h1
        class="mt-4 font-display text-[2rem] leading-[1.15] tracking-tight text-balance text-foreground sm:text-[2.5rem]"
      >
        {title}
      </h1>

      {
        description && (
          <p class="mt-4 font-display text-lg leading-relaxed text-muted-foreground italic">
            {description}
          </p>
        )
      }

      <hr class="rule mt-8" />
    </header>

    <Prose>
      <slot />
    </Prose>

    <PostTags tags={tags} />

    <Back label="Volver a Escritos" href="/writings" class="mt-10" />
  </article>
</BaseLayout>
